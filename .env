# Default app config — kids audience (FamHop). The adults sibling deploy
# overrides these via Cloudflare Pages env vars or an `--env` build flag.
VITE_APP_AUDIENCE=kids
VITE_APP_BRAND=FamHop
VITE_APP_TAGLINE=Plan · Hop · Repeat.
VITE_APP_HERO_TITLE=Plan the weekend — together.
VITE_APP_HERO_SUB=Pick the kids' age, interests, constraints, then a vibe. Get 3 family stops. Share with co-parents to vote.
VITE_APP_PARTNERS_LABEL=co-parents
VITE_APP_GROUP_LABEL=the family
VITE_APP_PLAN_NOUN=family plan
VITE_APP_OG_TITLE=FamHop — Plan the weekend with the kids
VITE_APP_OG_DESCRIPTION=Pick a vibe. Get a 3-stop Bay Area family plan with parks, libraries, museums and weekend events — then share with co-parents to vote.
VITE_APP_OG_IMAGE=https://famhop.com/og-image.png
VITE_APP_SITE_URL=https://famhop.com/
