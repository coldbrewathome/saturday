{
  "name": "weekend-with-kids",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "ingest:bay-area": "node scripts/ingest-bay-area.mjs",
    "ingest:events": "node scripts/ingest-events.mjs",
    "publish:events": "node scripts/publish-events.mjs",
    "match:places": "node scripts/match-google-places.mjs",
    "match:places:osm": "node scripts/match-google-places-osm.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:events": "node scripts/validate-events.mjs",
    "test": "npm run test:unit && npm run test:planner",
    "test:unit": "node --test tests/*.test.mjs",
    "test:planner": "vitest run tests/*.test.ts",
    "ci:worker": "npm --prefix worker run typecheck",
    "ci": "npm run test && npm run validate:data && npm run validate:events && npm run build && npm run ci:worker"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
