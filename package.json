{
  "name": "famhop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && node scripts/generate-seo-pages.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "ingest:bay-area": "node scripts/ingest-bay-area.mjs",
    "ingest:events": "node scripts/ingest-events.mjs && node scripts/generate-featured-plans.mjs",
    "ingest:spots:all": "node scripts/ingest-bay-area.mjs --all",
    "ingest:events:all": "node scripts/ingest-events-all.mjs",
    "ingest:metros": "npm run ingest:spots:all && npm run ingest:events:all",
    "ingest:plans": "node scripts/generate-featured-plans.mjs",
    "publish:events": "node scripts/publish-events.mjs",
    "publish:events:all": "node scripts/publish-events-all.mjs",
    "build:data-site": "node scripts/build-data-site.mjs",
    "deploy:data": "npm run build:data-site && npx wrangler pages deploy data-site/dist --project-name=famhop-data --branch=main --commit-dirty=true",
    "build:adults": "vite build --mode adults && node scripts/generate-seo-pages.mjs",
    "deploy:adults": "npm run build:adults && npx wrangler pages deploy dist --project-name=nighthop --branch=main --commit-dirty=true",
    "match:places": "node scripts/match-google-places.mjs",
    "match:places:osm": "node scripts/match-google-places-osm.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:data:all": "node scripts/validate-data.mjs --all",
    "validate:events": "node scripts/validate-events.mjs",
    "validate:events:all": "node scripts/validate-events.mjs --all",
    "test": "npm run test:unit && npm run test:planner",
    "test:unit": "node --test tests/*.test.mjs",
    "test:planner": "vitest run tests/*.test.ts",
    "ci:worker": "npm --prefix worker run typecheck",
    "ci": "npm run test && npm run validate:data:all && npm run validate:events:all && npm run build && npm run ci:worker"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
