# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/)
#
# /data/* is the shared cross-app data feed (multi-metro places + tagged events).
# CORS=* lets sibling apps (e.g. an upcoming adults-audience frontend on a
# different domain) fetch the JSON directly. The data is already public via
# Cloudflare Pages, so opening it for cross-origin reads is purely a header
# adjustment, not a security change.
/data/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=30, s-maxage=120, stale-while-revalidate=60
  X-Robots-Tag: noindex

/llms.txt
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

# Vite emits content-hashed filenames in /assets/, so the bytes for a given
# URL never change — safe to cache forever. The default Pages cache is 4h
# with must-revalidate, which forces a 304 round-trip for repeat visitors
# on every entry. Marking these immutable lets the browser skip the network
# entirely until a new build ships (with a new hash, and therefore a new URL).
/assets/*
  Cache-Control: public, max-age=31536000, immutable
